# Database
POSTGRES_DB=dovetail
POSTGRES_USER=dovetail
POSTGRES_PASSWORD=dovetail
POSTGRES_PORT=5432
DATABASE_URL=postgres://dovetail:dovetail@localhost:5432/dovetail
# SSL — set to true for Azure or any Postgres host requiring SSL.
# Not needed for local Docker Compose (no SSL).
# DB_SSL=true

# OAuth — fill in the provider you're using
OAUTH_PROVIDER=google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# ENTRA_CLIENT_ID=
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_SECRET=

# Auth
NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3000
DEV_AUTH_ENABLED=true

# Embeddings
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=
# EMBEDDING_BASE_URL=

# API URLs
# In production, both should point to the public domain (e.g. https://dovetail.example.com)
# so browser requests route through the reverse proxy.
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# RAG API
RAG_API_KEY=change-me

# MCP server (apps/mcp)
# MCP_API_KEY is a Dovetail admin-issued API key, scoped via the admin UI to the
# knowledge bases the MCP server should expose. Generate one at /admin/api-keys.
MCP_PORT=3002
MCP_API_BASE_URL=http://localhost:3001
MCP_API_KEY=
MCP_REQUEST_TIMEOUT_MS=15000
